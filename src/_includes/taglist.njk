{#
  Display list of tags for posts
#}
<ul class="taglist" aria-label="Tags">
  <li aria-hidden="true">Tags:&nbsp;</li>
  {%- for tag in tagsdata -%}
    {%- set tagUrl -%}/tags/{{ tag | slugify }}/{%- endset -%}
    <li><a href="{{ tagUrl }}">{{ tag }}</a>&nbsp;&nbsp;</li>
  {%- endfor -%}
  <li><a href="#alltags">All Tags</a></li>
</ul>
